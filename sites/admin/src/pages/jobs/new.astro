---
import '../../styles/global.css';
---

<script>
  const API_URL = 'https://tennis-admin-api.vnyson.workers.dev';

  let players = [];
  let selectedPlayer = null;

  async function loadPlayers() {
    try {
      const response = await fetch(`${API_URL}/api/players`);
      if (!response.ok) throw new Error('Failed to fetch players');
      players = await response.json();
      populatePlayerDropdown();
    } catch (error) {
      console.error('Error loading players:', error);
    }
  }

  function populatePlayerDropdown() {
    const select = document.getElementById('player_select');
    if (!select) return;

    select.innerHTML = '<option value="">Select a player...</option>';
    players.forEach(player => {
      const option = document.createElement('option');
      option.value = player.id;
      option.textContent = player.name;
      select.appendChild(option);
    });
  }

  function handlePlayerChange(event) {
    const playerId = event.target.value;
    selectedPlayer = players.find(p => p.id === playerId);
    
    if (selectedPlayer) {
      document.getElementById('player_name').value = selectedPlayer.name || '';
      document.getElementById('phone').value = selectedPlayer.phone || '';
      document.getElementById('string_mains').value = selectedPlayer.string_pref || '';
      document.getElementById('tension_mains').value = selectedPlayer.tension || '';
      
      // Auto-fill racquet if player has one
      if (selectedPlayer.racquet) {
        document.getElementById('racquet').value = selectedPlayer.racquet;
      }
    }
  }

  async function handleSubmit(event) {
    event.preventDefault();
    
    const formData = new FormData(event.target);
    const data = {
      player_id: selectedPlayer?.id || null,
      player_name: formData.get('player_name'),
      phone: formData.get('phone'),
      racquet: formData.get('racquet'),
      string_mains: formData.get('string_mains'),
      string_crosses: formData.get('string_crosses'),
      tension_mains: formData.get('tension_mains'),
      tension_crosses: formData.get('tension_crosses'),
      tension_unit: formData.get('tension_unit'),
      notes: formData.get('notes'),
      status: 'in_queue',
      priority: formData.get('rush') === 'on' ? 'rush' : 'normal',
    };

    try {
      const response = await fetch(`${API_URL}/api/stringing`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (!response.ok) throw new Error('Failed to create job');
      
      window.location.href = '/jobs';
    } catch (error) {
      console.error('Error creating job:', error);
      alert('Failed to create job. Please try again.');
    }
  }

  // Load players on page load
  document.addEventListener('DOMContentLoaded', () => {
    loadPlayers();
    
    const form = document.querySelector('form');
    if (form) {
      form.addEventListener('submit', handleSubmit);
    }

    const playerSelect = document.getElementById('player_select');
    if (playerSelect) {
      playerSelect.addEventListener('change', handlePlayerChange);
    }
  });
</script>

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>New Drop Off - Tennis Admin</title>
	</head>
	<body class="bg-gray-50">
		<div class="min-h-screen">
			<nav class="bg-white shadow-sm">
				<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
					<div class="flex justify-between h-16">
						<div class="flex">
							<div class="flex-shrink-0 flex items-center">
								<h1 class="text-xl font-bold text-gray-900">Tennis Admin</h1>
							</div>
							<div class="hidden sm:ml-6 sm:flex sm:space-x-8">
								<a href="/" class="border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium">Dashboard</a>
								<a href="/inventory" class="border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium">Inventory</a>
								<a href="/jobs" class="border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium">Jobs</a>
								<a href="/players" class="border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium">Players</a>
							</div>
						</div>
					</div>
				</div>
			</nav>

			<main class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
				<div class="px-4 py-6 sm:px-0">
					<div class="mb-6">
						<a href="/jobs" class="text-indigo-600 hover:text-indigo-800 text-sm font-medium">← Back to Jobs</a>
					</div>
					<h2 class="text-2xl font-bold text-gray-900 mb-6">New Drop Off</h2>

					<div class="bg-white shadow rounded-lg">
						<div class="px-4 py-5 sm:p-6">
							<form class="space-y-6">
								<div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-6">
									<div class="sm:col-span-3">
										<label for="player_select" class="block text-sm font-medium text-gray-700">Select Player</label>
										<select name="player_select" id="player_select" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm">
											<option value="">Select a player...</option>
										</select>
									</div>

									<div class="sm:col-span-3">
										<label for="rush" class="block text-sm font-medium text-gray-700">Rush Job</label>
										<div class="mt-2">
											<input type="checkbox" name="rush" id="rush" class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded" />
											<span class="ml-2 text-sm text-gray-600">Mark as rush job</span>
										</div>
									</div>

									<div class="sm:col-span-3">
										<label for="player_name" class="block text-sm font-medium text-gray-700">Player Name</label>
										<input type="text" name="player_name" id="player_name" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" />
									</div>

									<div class="sm:col-span-3">
										<label for="phone" class="block text-sm font-medium text-gray-700">Phone</label>
										<input type="text" name="phone" id="phone" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" />
									</div>

									<div class="sm:col-span-3">
										<label for="racquet" class="block text-sm font-medium text-gray-700">Racquet</label>
										<input type="text" name="racquet" id="racquet" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" placeholder="e.g., Wilson Pro Staff 97" />
									</div>

									<div class="sm:col-span-3">
										<label for="string_mains" class="block text-sm font-medium text-gray-700">String (Mains)</label>
										<input type="text" name="string_mains" id="string_mains" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" />
									</div>

									<div class="sm:col-span-3">
										<label for="string_crosses" class="block text-sm font-medium text-gray-700">String (Crosses)</label>
										<input type="text" name="string_crosses" id="string_crosses" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" />
									</div>

									<div class="sm:col-span-2">
										<label for="tension_mains" class="block text-sm font-medium text-gray-700">Tension (Mains)</label>
										<input type="text" name="tension_mains" id="tension_mains" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" placeholder="e.g., 54" />
									</div>

									<div class="sm:col-span-2">
										<label for="tension_crosses" class="block text-sm font-medium text-gray-700">Tension (Crosses)</label>
										<input type="text" name="tension_crosses" id="tension_crosses" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" placeholder="e.g., 52" />
									</div>

									<div class="sm:col-span-2">
										<label for="tension_unit" class="block text-sm font-medium text-gray-700">Unit</label>
										<select name="tension_unit" id="tension_unit" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm">
											<option value="lb">lb</option>
											<option value="kg">kg</option>
										</select>
									</div>

									<div class="sm:col-span-6">
										<label for="notes" class="block text-sm font-medium text-gray-700">Notes</label>
										<textarea name="notes" id="notes" rows="3" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm"></textarea>
									</div>
								</div>

								<div class="flex justify-end">
									<button type="submit" class="inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
										Create Drop Off
									</button>
								</div>
							</form>
						</div>
					</div>
				</div>
			</main>
		</div>
	</body>
</html>
